#!name=Bilibili Force HK CDN
#!desc=Force Bilibili CDN to cn-hk-eq-01-01.bilivideo.com (CCB style)
#!author=custom
#!version=1.0

[MITM]
hostname = api.bilibili.com, *.bilivideo.com, *.akamaized.net

[Script]
bilibili-playurl = type=http-response,pattern=^https:\/\/api\.bilibili\.com\/.*\/playurl,requires-body=1,max-size=0,script-path=data:application/javascript;base64,
